# FeasiblePlan — Gemini (Google ADK) configuration.
# Copy to `.env` and paste your key. `.env` is gitignored; never commit the key.
#
# Get a free key at: https://aistudio.google.com/apikey
#
# Use the AI Studio (Gemini Developer API) path — no GCP project/billing needed:
GOOGLE_GENAI_USE_VERTEXAI=FALSE
GOOGLE_API_KEY=PASTE_YOUR_KEY_HERE

# Optional: override the model (default: gemini-2.5-flash).
# On the free tier each model has its own daily request quota; if you hit a 429
# "RESOURCE_EXHAUSTED" (per-day), switch to another model's fresh bucket — e.g.
# gemini-2.5-flash-lite, which also has higher free limits. The app retries short
# per-minute/503 throttles and otherwise falls back to the offline mock.
# FEASIBLEPLAN_MODEL=gemini-2.5-flash-lite

# Force the offline mock (no LLM calls) without deleting your key — useful for
# quota-free development and deterministic demos. Comment out to use Gemini again.
# FEASIBLEPLAN_BACKEND=mock
