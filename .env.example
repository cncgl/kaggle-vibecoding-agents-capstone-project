# FeasiblePlan — Gemini (Google ADK) configuration.
# Copy to `.env` and paste your key. `.env` is gitignored; never commit the key.
#
# Get a free key at: https://aistudio.google.com/apikey
#
# Use the AI Studio (Gemini Developer API) path — no GCP project/billing needed:
GOOGLE_GENAI_USE_VERTEXAI=FALSE
GOOGLE_API_KEY=PASTE_YOUR_KEY_HERE

# Optional: override the model (default: gemini-2.5-flash).
# On the free tier each model has its own daily request quota; if you hit a 429
# "RESOURCE_EXHAUSTED" (per-day), switch to another model's fresh bucket — e.g.
# gemini-2.5-flash-lite, which also has higher free limits. The app retries short
# per-minute/503 throttles and otherwise falls back to the offline mock.
# FEASIBLEPLAN_MODEL=gemini-2.5-flash-lite

# --- Backend selection: gemini (default if key) | local | mock ---------------
#
# Force the offline mock (no LLM calls) — quota-free dev / deterministic demos:
# FEASIBLEPLAN_BACKEND=mock
#
# Use a LOCAL LLM instead of Gemini — no key, no quota, fully offline.
# Works with any OpenAI-compatible server:
#   - Ollama    : base URL http://localhost:11434/v1  (run `ollama pull <model>`)
#   - LM Studio : base URL http://localhost:1234/v1   (load a model, start server)
# A small 3B model runs but may not always converge; a 7-8B model (e.g.
# qwen2.5:7b, llama3.1:8b) is more reliable. Bad output safely falls back to mock.
# FEASIBLEPLAN_BACKEND=local
# FEASIBLEPLAN_LLM_BASE_URL=http://localhost:11434/v1
# FEASIBLEPLAN_LLM_MODEL=llama3.2:3b
